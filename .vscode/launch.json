{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "(Windows) Launch",
      "type": "cppvsdbg",
      "program": "${workspaceFolder}/out/pilotlight_python.exe",
      "console": "integratedTerminal",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/out/",
      "environment": []
    },
    {
      "name": "(Linux) Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/out/pilotlight_python",
      "args": [],
      "cwd": "${workspaceFolder}/out",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb"
    },
    {
        "name": "(MacOS) Launch",
        "type": "cppdbg",
        "targetArchitecture": "arm64",
        "program": "${workspaceFolder}/out/pilotlight_python",
        "externalConsole": false,
        "MIMode": "lldb",
        "request": "launch",
        "args": [],
        "stopAtEntry": false,
        "cwd": "${workspaceFolder}/out/",
        "environment": []
    }
  ]
}
